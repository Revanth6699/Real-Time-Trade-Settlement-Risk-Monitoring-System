
---

# .gitignore

```
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so

# Virtual Environment
venv/
.venv/
env/

# Environment
.env
.env.*
!.env.example

# VS Code
.vscode/

# JetBrains
.idea/

# macOS
.DS_Store

# Windows
Thumbs.db

# Logs
logs/
*.log

# Coverage
.coverage
htmlcov/
.pytest_cache/

# Jupyter
.ipynb_checkpoints/

# Build
build/
dist/
*.egg-info/

# Docker
docker-data/
*.pid

# Redis
dump.rdb

# Grafana
grafana/data/
grafana/plugins/

# Prometheus
prometheus/data/

# Alertmanager
alertmanager/data/

# PostgreSQL
postgres-data/

# Model Files
*.h5
*.keras
*.onnx
*.ckpt

# ML Cache
.mlflow/
wandb/

# Secrets
credentials.json
service-account.json
google-credentials.json
*.pem
*.key

# Misc
.cache/
temp/
tmp/
```

